{
  "version": 1,
  "description": "HPCA Mode 6 evaluation manifest. Phased & gated by kill switches. See docs/findings/hpca_evaluation_plan_v1.md for full plan and gates. All stages target the canonical config (1-core, L1=32KB/8w, L2=256KB/8w, L3=2MB matched per-core to DROPLET/GRASP).",
  "defaults": {
    "l1d_size": "32kB",
    "l1d_ways": "8",
    "l2_size": "256kB",
    "l2_ways": "8",
    "l3_sizes": ["2MB"],
    "l3_ways": "16",
    "line_size": "64",
    "timeout_cache": 5400,
    "timeout_gem5": 7200,
    "timeout_sniper": 5400,
    "sniper_root": "bench/include/sniper_sim/snipersim",
    "sniper_frontend": "live",
    "sniper_omp_wait_policy": "passive",
    "sniper_memory_limit_gb": 16,
    "sniper_base_config": "graphbrew/graph_sniper",
    "sniper_mimicos_memory_mb": 4096,
    "sniper_mimicos_kernel_mb": 128,
    "no_build": true
  },
  "profiles": {
    "smoke":      "Phase 1.3: 15-min toolchain end-to-end verification on email-Eu-core.",
    "killswitch": "Phase 1.5: 1-2h GO/NO-GO gates before full sweep.",
    "phase_2":    "Phase 2: minimal baseline stability on common graphs.",
    "phase_3":    "Phase 3: incremental ECG build-up.",
    "phase_4":    "Phase 4: sensitivity sweeps (L3, AMPLIFY, dedup, CHARGED).",
    "phase_5":    "Phase 5: cycle-accurate cross-validation (Sniper, optional gem5)."
  },
  "benchmark_options": {
    "file_dbg": {
      "pr":   "-f {graph_path} -s -o 5 -n 1 -i 2",
      "bfs":  "-f {graph_path} -s -o 5 -n 1 -r 0",
      "sssp": "-f {graph_path} -s -o 5 -n 1 -r 0 -d 1"
    }
  },
  "graph_sets": {
    "smoke": [
      {"name": "email-Eu-core", "path": "results/graphs/email-Eu-core/email-Eu-core.sg", "options_key": "file_dbg"}
    ],
    "killswitch_large": [
      {"name": "com-orkut",         "path": "results/graphs/com-orkut/com-orkut.sg",                 "options_key": "file_dbg"},
      {"name": "soc-LiveJournal1",  "path": "results/graphs/soc-LiveJournal1/soc-LiveJournal1.sg",  "options_key": "file_dbg"}
    ],
    "killswitch_baseline_parity": [
      {"name": "email-Eu-core", "path": "results/graphs/email-Eu-core/email-Eu-core.sg", "options_key": "file_dbg"},
      {"name": "web-Google",    "path": "results/graphs/web-Google/web-Google.sg",       "options_key": "file_dbg"}
    ],
    "killswitch_sniper": [
      {"name": "delaunay_n19",  "path": "results/graphs/delaunay_n19/delaunay_n19.sg",   "options_key": "file_dbg"}
    ],
    "common_corpus": [
      {"name": "email-Eu-core",     "path": "results/graphs/email-Eu-core/email-Eu-core.sg",         "options_key": "file_dbg"},
      {"name": "web-Google",        "path": "results/graphs/web-Google/web-Google.sg",               "options_key": "file_dbg"},
      {"name": "cit-Patents",       "path": "results/graphs/cit-Patents/cit-Patents.sg",             "options_key": "file_dbg"},
      {"name": "soc-LiveJournal1",  "path": "results/graphs/soc-LiveJournal1/soc-LiveJournal1.sg",   "options_key": "file_dbg"},
      {"name": "com-orkut",         "path": "results/graphs/com-orkut/com-orkut.sg",                 "options_key": "file_dbg"}
    ]
  },
  "stages": [
    {
      "name": "phase_1_3_smoke_replacement",
      "kind": "roi_matrix",
      "profiles": ["smoke"],
      "suite": "cache-sim",
      "graph_set": "smoke",
      "benchmarks": ["pr"],
      "policies": ["LRU", "GRASP", "POPT", "ECG:DBG_ONLY", "ECG:POPT_PRIMARY"],
      "prefetcher": "none",
      "out_subdir": "phase_1_3_smoke/replacement"
    },
    {
      "name": "phase_1_3_smoke_droplet",
      "kind": "roi_matrix",
      "profiles": ["smoke"],
      "suite": "cache-sim",
      "graph_set": "smoke",
      "benchmarks": ["pr"],
      "policies": ["ECG:DBG_ONLY"],
      "prefetcher": "DROPLET",
      "ecg_pfx_lookahead": "16",
      "out_subdir": "phase_1_3_smoke/droplet_lh16"
    },
    {
      "name": "phase_1_3_smoke_mode6_charged0_amp1",
      "kind": "roi_matrix",
      "profiles": ["smoke"],
      "suite": "cache-sim",
      "graph_set": "smoke",
      "benchmarks": ["pr"],
      "policies": ["ECG:DBG_ONLY"],
      "prefetcher": "ECG_PFX",
      "ecg_pfx_mode": "per_edge",
      "ecg_pfx_lookahead": "8",
      "env": {
        "ECG_EDGE_MASK_CHARGED": "0",
        "ECG_EDGE_MASK_AMPLIFY": "1",
        "ECG_EDGE_MASK_LOOKAHEAD": "8"
      },
      "out_subdir": "phase_1_3_smoke/mode6_charged0_amp1"
    },
    {
      "name": "phase_1_5_kill1_droplet_lh8",
      "kind": "roi_matrix",
      "profiles": ["killswitch"],
      "suite": "cache-sim",
      "graph_set": "killswitch_large",
      "benchmarks": ["pr"],
      "policies": ["ECG:DBG_ONLY"],
      "prefetcher": "DROPLET",
      "ecg_pfx_lookahead": "8",
      "l3_sizes": ["2MB", "8MB"],
      "out_subdir": "phase_1_5_kill1/droplet_lh8"
    },
    {
      "name": "phase_1_5_kill1_droplet_lh16",
      "kind": "roi_matrix",
      "profiles": ["killswitch"],
      "suite": "cache-sim",
      "graph_set": "killswitch_large",
      "benchmarks": ["pr"],
      "policies": ["ECG:DBG_ONLY"],
      "prefetcher": "DROPLET",
      "ecg_pfx_lookahead": "16",
      "l3_sizes": ["2MB", "8MB"],
      "out_subdir": "phase_1_5_kill1/droplet_lh16"
    },
    {
      "name": "phase_1_5_kill1_mode6_charged0_amp1",
      "kind": "roi_matrix",
      "profiles": ["killswitch"],
      "suite": "cache-sim",
      "graph_set": "killswitch_large",
      "benchmarks": ["pr"],
      "policies": ["ECG:DBG_ONLY"],
      "prefetcher": "ECG_PFX",
      "ecg_pfx_mode": "per_edge",
      "ecg_pfx_lookahead": "8",
      "env": {
        "ECG_EDGE_MASK_CHARGED": "0",
        "ECG_EDGE_MASK_AMPLIFY": "1",
        "ECG_EDGE_MASK_LOOKAHEAD": "8"
      },
      "l3_sizes": ["2MB", "8MB"],
      "out_subdir": "phase_1_5_kill1/mode6_charged0_amp1"
    },
    {
      "name": "phase_1_5_kill2_baseline_parity",
      "kind": "roi_matrix",
      "profiles": ["killswitch"],
      "suite": "cache-sim",
      "graph_set": "killswitch_baseline_parity",
      "benchmarks": ["pr"],
      "policies": ["LRU", "GRASP", "POPT", "ECG:DBG_ONLY", "ECG:POPT_PRIMARY"],
      "prefetcher": "none",
      "l3_sizes": ["2MB"],
      "out_subdir": "phase_1_5_kill2/baseline_parity"
    },
    {
      "name": "phase_2_baselines_lru",
      "kind": "roi_matrix",
      "profiles": ["phase_2"],
      "suite": "cache-sim",
      "graph_set": "common_corpus",
      "benchmarks": ["pr"],
      "policies": ["LRU", "GRASP", "POPT", "ECG:DBG_ONLY", "ECG:POPT_PRIMARY"],
      "prefetcher": "none",
      "out_subdir": "phase_2_baselines/lru_noprefetch"
    },
    {
      "name": "phase_2_baselines_droplet_lh8",
      "kind": "roi_matrix",
      "profiles": ["phase_2"],
      "suite": "cache-sim",
      "graph_set": "common_corpus",
      "benchmarks": ["pr"],
      "policies": ["ECG:DBG_ONLY"],
      "prefetcher": "DROPLET",
      "ecg_pfx_lookahead": "8",
      "out_subdir": "phase_2_baselines/droplet_lh8"
    },
    {
      "name": "phase_3_ecg_buildup_mode2",
      "kind": "roi_matrix",
      "profiles": ["phase_3"],
      "suite": "cache-sim",
      "graph_set": "common_corpus",
      "benchmarks": ["pr"],
      "policies": ["ECG:DBG_ONLY"],
      "prefetcher": "ECG_PFX",
      "ecg_pfx_mode": "popt",
      "ecg_pfx_lookahead": "8",
      "ecg_pfx_window": "16",
      "out_subdir": "phase_3_buildup/mode2_popt_k1_lh8"
    },
    {
      "name": "phase_3_ecg_buildup_mode6_amp0_charged0",
      "kind": "roi_matrix",
      "profiles": ["phase_3"],
      "suite": "cache-sim",
      "graph_set": "common_corpus",
      "benchmarks": ["pr"],
      "policies": ["ECG:DBG_ONLY"],
      "prefetcher": "ECG_PFX",
      "ecg_pfx_mode": "per_edge",
      "ecg_pfx_lookahead": "8",
      "env": {
        "ECG_EDGE_MASK_CHARGED": "0",
        "ECG_EDGE_MASK_AMPLIFY": "0",
        "ECG_EDGE_MASK_LOOKAHEAD": "8"
      },
      "out_subdir": "phase_3_buildup/mode6_charged0_amp0"
    },
    {
      "name": "phase_3_ecg_buildup_mode6_amp1_charged0",
      "kind": "roi_matrix",
      "profiles": ["phase_3"],
      "suite": "cache-sim",
      "graph_set": "common_corpus",
      "benchmarks": ["pr"],
      "policies": ["ECG:DBG_ONLY"],
      "prefetcher": "ECG_PFX",
      "ecg_pfx_mode": "per_edge",
      "ecg_pfx_lookahead": "8",
      "env": {
        "ECG_EDGE_MASK_CHARGED": "0",
        "ECG_EDGE_MASK_AMPLIFY": "1",
        "ECG_EDGE_MASK_LOOKAHEAD": "8"
      },
      "out_subdir": "phase_3_buildup/mode6_charged0_amp1"
    },
    {
      "name": "phase_3_ecg_buildup_mode6_amp1_charged1",
      "kind": "roi_matrix",
      "profiles": ["phase_3"],
      "suite": "cache-sim",
      "graph_set": "common_corpus",
      "benchmarks": ["pr"],
      "policies": ["ECG:DBG_ONLY"],
      "prefetcher": "ECG_PFX",
      "ecg_pfx_mode": "per_edge",
      "ecg_pfx_lookahead": "8",
      "env": {
        "ECG_EDGE_MASK_CHARGED": "1",
        "ECG_EDGE_MASK_AMPLIFY": "1",
        "ECG_EDGE_MASK_LOOKAHEAD": "8"
      },
      "out_subdir": "phase_3_buildup/mode6_charged1_amp1_negcontrol"
    }
  ]
}
