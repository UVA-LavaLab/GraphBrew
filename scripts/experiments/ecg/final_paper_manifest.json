{
  "version": 1,
  "description": "GraphBrew ECG final-paper run manifest. Profiles expand into resumable roi_matrix/proof_matrix jobs.",
  "defaults": {
    "l1d_size": "1kB",
    "l2_size": "2kB",
    "l3_sizes": ["4kB"],
    "l3_ways": "16",
    "line_size": "64",
    "timeout_cache": 1800,
    "timeout_gem5": 7200,
    "timeout_sniper": 600,
    "sniper_root": "bench/include/sniper_sim/snipersim",
    "sniper_frontend": "live",
    "sniper_omp_wait_policy": "passive",
    "sniper_memory_limit_gb": 16,
    "sniper_base_config": "graphbrew/graph_sniper",
    "sniper_mimicos_memory_mb": 4096,
    "sniper_mimicos_kernel_mb": 128,
    "no_build": true
  },
  "profiles": {
    "rehearsal": "Validated synthetic g12 preflight before multi-day runs.",
    "sniper_smoke": "Fast Sniper PR-kernel smoke through roi_matrix.py --suite sniper after overlays are applied.",
    "sniper_kernel_smoke": "Safe Sniper builder-free PR/BFS/SSSP kernel smoke suite with the full final policy-label surface.",
    "sniper_droplet_smoke": "Safe Sniper virtual-address DROPLET smoke where PR/BFS issue useful prefetches.",
    "sniper_sift_benchmark_smoke": "Bounded Sniper SIFT full-wrapper PR smoke with explicit allow flag and memory cap.",
    "sniper_sift_benchmark_suite": "Bounded Sniper SIFT full-wrapper PR/BFS/SSSP smoke suite with explicit allow flag and memory cap.",
    "sniper_sift_replacement_smoke": "Bounded Sniper SIFT full-wrapper PR/BFS/SSSP replacement-policy smoke with graph-aware policies.",
    "sniper_sift_file_smoke": "Bounded Sniper SIFT file-backed email-Eu-core PR/BFS/SSSP smoke with explicit allow flag and memory cap.",
    "sniper_sift_file_replacement_smoke": "Bounded Sniper SIFT file-backed email-Eu-core replacement-policy smoke with graph-aware policies.",
    "sniper_sift_file_droplet_smoke": "Bounded Sniper SIFT file-backed email-Eu-core DROPLET smoke including SSSP useful-prefetch validation.",
    "sniper_sift_file_thread_smoke": "Bounded Sniper SIFT file-backed PR thread-scaling smoke on email-Eu-core using passive OpenMP waits.",
    "sniper_sift_ecg_pfx_smoke": "Bounded Sniper SIFT synthetic PR/BFS/SSSP ECG_PFX smoke with useful prefetch counters.",
    "sniper_sift_file_ecg_pfx_smoke": "Bounded Sniper SIFT file-backed email-Eu-core ECG_PFX smoke with benchmark-specific lookahead knobs.",
    "sniper_sift_cit_patents_smoke": "Bounded Sniper SIFT cit-Patents PR/LRU scale-out smoke.",
    "sniper_sift_cit_patents_long": "Dedicated local or Slurm Sniper SIFT cit-Patents PR/LRU scale-out run with a longer timeout.",
    "gem5_ecg_pfx_tiny_smoke": "Tiny experimental gem5 ECG_PFX smoke for PR/BFS/SSSP issued/useful counter validation.",
    "sniper_thread_scaling": "Safe Sniper PR-kernel thread/core runner-surface smoke; full benchmark scaling waits for Sniper/SDE run-mode tuning.",
    "available_sniper_replacement": "Placeholder for available-local Sniper replacement sweep after Sniper/SDE full-wrapper or trace-reuse run mode is fixed.",
    "final_sniper_replacement": "Placeholder for final Sniper replacement sweep after Sniper/SDE full-wrapper or trace-reuse run mode is fixed.",
    "final_sniper_droplet": "Placeholder for final Sniper DROPLET sweep after full run mode and final-workload prefetch counters prove active.",
    "available_replacement": "Replacement-only gem5 sweep on graph files currently present in results/graphs.",
    "final_cache_sim": "Large-graph cache_sim replacement-only sweep.",
    "available_cache_sim_ecg_pfx": "Available-local cache_sim ECG_PFX sweep before large graph staging.",
    "final_cache_sim_ecg_pfx": "Large-graph cache_sim ECG_PFX sweep for graph-aware prefetch evidence.",
    "final_replacement": "Large-graph gem5 replacement-only sweep for PR/BFS/SSSP.",
    "final_droplet": "Large-graph gem5 DROPLET baseline sweep after actual-edge smokes pass."
  },
  "benchmark_options": {
    "synthetic_g12": {
      "pr": "-g 12 -k 16 -o 5 -n 1 -i 2",
      "bfs": "-g 12 -k 16 -o 5 -n 1 -r 0",
      "sssp": "-g 12 -k 16 -o 5 -n 1 -r 0 -d 1"
    },
    "synthetic_ecg_pfx_tiny": {
      "pr": "-g 7 -k 8 -o 5 -n 1 -i 1",
      "bfs": "-g 6 -k 4 -o 5 -n 1 -r 0",
      "sssp": "-g 6 -k 4 -o 5 -n 1 -r 0 -d 1"
    },
    "synthetic_sniper_ecg_pfx_smoke": {
      "pr": "-g 6 -k 8 -o 2 -n 1 -i 1",
      "bfs": "-g 6 -k 8 -o 2 -n 1 -r 0",
      "sssp": "-g 6 -k 8 -o 2 -n 1 -r 0 -d 1"
    },
    "file_dbg": {
      "pr": "-f {graph_path} -s -o 5 -n 1 -i 2",
      "bfs": "-f {graph_path} -s -o 5 -n 1 -r 0",
      "sssp": "-f {graph_path} -s -o 5 -n 1 -r 0 -d 1"
    }
  },
  "graph_sets": {
    "synthetic_g12": [
      {"name": "synthetic_g12", "options_key": "synthetic_g12"}
    ],
    "synthetic_ecg_pfx_tiny": [
      {"name": "synthetic_ecg_pfx_tiny", "options_key": "synthetic_ecg_pfx_tiny"}
    ],
    "synthetic_sniper_ecg_pfx_smoke": [
      {"name": "synthetic_sniper_ecg_pfx_smoke", "options_key": "synthetic_sniper_ecg_pfx_smoke"}
    ],
    "email_core": [
      {"name": "email-Eu-core", "path": "results/graphs/email-Eu-core/email-Eu-core.sg", "options_key": "file_dbg"}
    ],
    "cit_patents": [
      {"name": "cit-Patents", "path": "results/graphs/cit-Patents/cit-Patents.sg", "options_key": "file_dbg"}
    ],
    "local_large": [
      {"name": "soc-pokec", "path": "results/graphs/soc-pokec/soc-pokec.sg", "options_key": "file_dbg"},
      {"name": "soc-LiveJournal1", "path": "results/graphs/soc-LiveJournal1/soc-LiveJournal1.sg", "options_key": "file_dbg"},
      {"name": "com-orkut", "path": "results/graphs/com-orkut/com-orkut.sg", "options_key": "file_dbg"},
      {"name": "cit-Patents", "path": "results/graphs/cit-Patents/cit-Patents.sg", "options_key": "file_dbg"}
    ],
    "available_local": [
      {"name": "email-Eu-core", "path": "results/graphs/email-Eu-core/email-Eu-core.sg", "options_key": "file_dbg"},
      {"name": "cit-Patents", "path": "results/graphs/cit-Patents/cit-Patents.sg", "options_key": "file_dbg"}
    ]
  },
  "stages": [
    {
      "name": "01_cache_sim_component_proof",
      "kind": "proof_matrix",
      "profiles": ["rehearsal"],
      "benchmarks": ["pr", "bfs", "sssp"],
      "l3_sizes": ["4kB"],
      "out_subdir": "01_cache_sim_component_proof"
    },
    {
      "name": "02_gem5_replacement_rehearsal",
      "kind": "roi_matrix",
      "profiles": ["rehearsal"],
      "suite": "gem5",
      "graph_set": "synthetic_g12",
      "benchmarks": ["pr", "bfs", "sssp"],
      "policies": ["LRU", "SRRIP", "GRASP", "POPT_CHARGED", "POPT", "ECG:DBG_ONLY", "ECG:DBG_PRIMARY_CHARGED", "ECG:DBG_PRIMARY", "ECG:POPT_PRIMARY"],
      "prefetcher": "none",
      "out_subdir": "02_gem5_replacement_rehearsal"
    },
    {
      "name": "03_droplet_actual_edge_rehearsal",
      "kind": "roi_matrix",
      "profiles": ["rehearsal"],
      "suite": "gem5",
