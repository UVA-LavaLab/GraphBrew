      "policies": ["LRU", "SRRIP", "GRASP", "POPT_CHARGED", "POPT", "ECG:DBG_ONLY", "ECG:DBG_PRIMARY_CHARGED", "ECG:DBG_PRIMARY", "ECG:POPT_PRIMARY"],
      "prefetcher": "none",
      "sniper_workload": "pr_kernel_smoke",
      "sniper_cores": 1,
      "sniper_address_domain": "virtual",
      "out_subdir": "04_sniper_pr_kernel_smoke",
      "timeout_sniper": 600
    },
    {
