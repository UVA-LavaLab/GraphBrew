{
  "version": 2,
  "description": "ECG successor HPCA artifact manifest.",
  "defaults": {
    "l1d_size": "32kB",
    "l2_size": "256kB",
    "l1d_ways": "8",
    "l2_ways": "8",
    "l3_sizes": ["2MB"],
    "l3_ways": "16",
    "line_size": "64",
    "timeout_cache": 1800,
    "timeout_gem5": 7200,
    "timeout_sniper": 21600,
    "sniper_root": "bench/include/sniper_sim/snipersim",
    "sniper_frontend": "sift",
    "sniper_omp_wait_policy": "passive",
    "sniper_memory_limit_gb": 12,
    "sniper_base_config": "graphbrew/graph_sniper",
    "sniper_mimicos_memory_mb": 4096,
    "sniper_mimicos_kernel_mb": 128,
    "popt_reserve_model": "size_correct",
    "no_build": true
  },
  "profiles": {
    "ecg_smoke": "Fast cache_sim smoke for the complete ECG policy set.",
    "ecg_cache_sim_factorial": "Real-graph K1/K2 x StreamShield cache_sim factorial with the full baseline set.",
    "gem5_streamshield_mechanism": "Synthetic gem5 mechanism cell for fused K2 versus K2+StreamShield.",
    "sniper_streamshield_mechanism": "Synthetic Sniper mechanism cell for fused K2 versus K2+StreamShield.",
    "streamshield_sniper_realgraph": "Bounded web-Google PR Sniper matrix for LRU, SRRIP, GRASP, charged P-OPT, K2, and K2+StreamShield."
  },
  "benchmark_options": {
    "synthetic_pr": {
      "pr": "-g 12 -k 16 -o 5 -n 1 -i 1"
    },
    "synthetic_kron4_pr": {
      "pr": "-g 16 -k 4 -o 5 -n 1 -i 1"
    },
    "synthetic_kron16_pr": {
      "pr": "-g 16 -k 16 -o 5 -n 1 -i 1"
    },
    "file_pr_i1_dbg": {
      "pr": "-f {graph_path} -o 5 -n 1 -i 1"
    }
  },
  "graph_sets": {
    "synthetic_smoke": [
      {
        "name": "synthetic_g12",
        "options_key": "synthetic_pr",
        "l1d_size": "1kB",
        "l2_size": "2kB",
        "l3_ways": "4",
        "l3_sizes": ["4kB"],
        "structure_prefetch_degree": 8
      }
    ],
    "synthetic_kron4": [
      {
        "name": "kron_s16_k4",
        "options_key": "synthetic_kron4_pr",
        "l1d_size": "16kB",
        "l2_size": "64kB",
        "l3_ways": "16",
        "l3_sizes": ["128kB"],
        "structure_prefetch_degree": 8
      }
    ],
    "synthetic_kron16": [
      {
        "name": "kron_s16_k16",
        "options_key": "synthetic_kron16_pr",
        "l1d_size": "16kB",
        "l2_size": "64kB",
        "l3_ways": "16",
        "l3_sizes": ["128kB"],
        "structure_prefetch_degree": 8
      }
    ],
    "web_google_streamshield": [
      {
        "name": "web-Google",
        "path": "results/graphs/web-Google/web-Google.sg",
        "options_key": "file_pr_i1_dbg",
        "l1d_size": "32kB",
        "l2_size": "256kB",
        "l3_ways": "16",
        "l3_sizes": ["2MB"],
        "structure_prefetch_degree": 8
      }
    ],
    "factorial_graphs": [
      {
        "name": "web-Google",
        "path": "results/graphs/web-Google/web-Google.sg",
        "options_key": "file_pr_i1_dbg",
        "l3_sizes": ["2MB"],
        "structure_prefetch_degree": 8
      },
      {
        "name": "soc-pokec",
        "path": "results/graphs/soc-pokec/soc-pokec.sg",
        "options_key": "file_pr_i1_dbg",
        "l3_sizes": ["2MB"],
        "structure_prefetch_degree": 8
      },
      {
        "name": "cit-Patents",
        "path": "results/graphs/cit-Patents/cit-Patents.sg",
        "options_key": "file_pr_i1_dbg",
        "l3_sizes": ["8MB"],
        "structure_prefetch_degree": 8
      }
    ]
  },
  "stages": [
    {
      "name": "01_ecg_cache_sim_smoke",
      "kind": "roi_matrix",
      "profiles": ["ecg_smoke"],
      "suite": "cache-sim",
      "graph_set": "synthetic_smoke",
      "benchmarks": ["pr"],
      "policies": ["LRU", "SRRIP", "GRASP", "POPT", "ECG:K2", "ECG:K2_STREAMSHIELD"],
      "popt_reserve_model": "size_correct",
      "prefetcher": "STRIDE",
      "out_subdir": "01_ecg_cache_sim_smoke",
      "timeout_cache": 600
    },
    {
      "name": "20_cache_sim_streamshield_factorial",
      "kind": "roi_matrix",
      "profiles": ["ecg_cache_sim_factorial"],
      "suite": "cache-sim",
      "graph_set": "factorial_graphs",
      "benchmarks": ["pr"],
      "policies": [
        "LRU",
        "SRRIP",
        "GRASP",
        "POPT",
        "ECG:K1",
        "ECG:K1_STREAMSHIELD",
        "ECG:K2",
        "ECG:K2_STREAMSHIELD"
      ],
      "popt_reserve_model": "size_correct",
      "prefetcher": "STRIDE",
      "out_subdir": "20_cache_sim_streamshield_factorial",
      "timeout_cache": 86400
    },
    {
      "name": "30_gem5_streamshield_mechanism",
      "kind": "roi_matrix",
      "profiles": ["gem5_streamshield_mechanism"],
      "suite": "gem5",
      "graph_set": "synthetic_kron4",
      "benchmarks": ["pr"],
      "policies": ["LRU", "SRRIP", "GRASP", "POPT", "ECG:K2", "ECG:K2_STREAMSHIELD"],
      "popt_reserve_model": "size_correct",
      "prefetcher": "STRIDE",
      "out_subdir": "30_gem5_streamshield_mechanism",
      "timeout_gem5": 21600,
      "env": {
        "GEM5_OPT": "bench/include/gem5_sim/gem5/build/RISCV/gem5.opt",
        "GEM5_KERNEL_SUFFIX": "_riscv_m5ops"
      }
    },
    {
      "name": "31_sniper_streamshield_mechanism",
      "kind": "roi_matrix",
      "profiles": ["sniper_streamshield_mechanism"],
      "suite": "sniper",
      "graph_set": "synthetic_kron16",
      "benchmarks": ["pr"],
      "policies": ["LRU", "SRRIP", "GRASP", "POPT", "ECG:K2", "ECG:K2_STREAMSHIELD"],
      "popt_reserve_model": "size_correct",
      "prefetcher": "STRIDE",
      "sniper_workload": "sg_kernel",
      "sniper_frontend": "sift",
      "allow_sniper_sg_kernel_workload": true,
      "sniper_memory_limit_gb": 12,
      "sniper_address_domain": "virtual",
      "require_sniper_aslr_disable": true,
      "sniper_cores": 1,
      "out_subdir": "31_sniper_streamshield_mechanism",
      "timeout_sniper": 21600
    },
    {
      "name": "40_sniper_streamshield_realgraph",
      "kind": "roi_matrix",
      "profiles": ["streamshield_sniper_realgraph"],
      "suite": "sniper",
      "graph_set": "web_google_streamshield",
      "benchmarks": ["pr"],
      "policies": ["LRU", "SRRIP", "GRASP", "POPT", "ECG:K2", "ECG:K2_STREAMSHIELD"],
      "popt_reserve_model": "size_correct",
      "prefetcher": "STRIDE",
      "sniper_workload": "sg_kernel",
      "sniper_frontend": "sift",
      "allow_sniper_sg_kernel_workload": true,
      "sniper_memory_limit_gb": 12,
      "sniper_address_domain": "virtual",
      "require_sniper_aslr_disable": true,
      "sniper_cores": 1,
      "sniper_roi_icount": 100000000,
      "out_subdir": "40_sniper_streamshield_realgraph",
      "timeout_sniper": 21600
    }
  ]
}
