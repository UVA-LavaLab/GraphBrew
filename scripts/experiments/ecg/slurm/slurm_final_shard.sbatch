#!/bin/bash
#SBATCH --job-name=ecg-final
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=2
#SBATCH --mem=32G
#SBATCH --time=3-00:00:00
#SBATCH --exclusive
#SBATCH --output=results/slurm_logs/ecg_%A_%a.out
#SBATCH --error=results/slurm_logs/ecg_%A_%a.err
# Set these for your UVA allocation if needed:
# #SBATCH --account=<uva-allocation>
# #SBATCH --partition=<uva-partition>

set -euo pipefail

if [[ -z "${SHARDS:-}" ]]; then
  echo "SHARDS must point to the shard TSV generated by make_slurm_shards.py" >&2
  exit 2
fi
if [[ -z "${SLURM_ARRAY_TASK_ID:-}" ]]; then
  echo "SLURM_ARRAY_TASK_ID must be set by sbatch --array" >&2
  exit 2
fi

cd "${GRAPHBREW_ROOT:-$PWD}"
source .venv/bin/activate
mkdir -p results/slurm_logs
if [[ ! -r "$SHARDS" ]]; then
  echo "SHARDS is not readable: $SHARDS" >&2
  exit 2
fi

line_number=$((SLURM_ARRAY_TASK_ID + 1))
line=$(sed -n "${line_number}p" "$SHARDS")
if [[ -z "$line" ]]; then
  echo "No shard row for SLURM_ARRAY_TASK_ID=${SLURM_ARRAY_TASK_ID}" >&2
  exit 3
fi

field_count=$(awk -F '\t' '{print NF; exit}' <<< "$line")
if [[ "$field_count" -ne 6 ]]; then
  echo "Invalid shard row ${line_number}: expected 6 tab-separated fields, got ${field_count}" >&2
  echo "$line" >&2
  exit 4
fi
IFS=$'\t' read -r profile stage graph benchmark policy run_tag <<< "$line"
for field_name in profile stage graph benchmark policy run_tag; do
  if [[ -z "${!field_name}" ]]; then
    echo "Invalid shard row ${line_number}: empty ${field_name}" >&2
    echo "$line" >&2
    exit 4
  fi
done
safe_policy=${policy//:/_}
run_dir="results/ecg_experiments/final_paper_runs/slurm/${run_tag}/${profile}_${graph}_${benchmark}_${safe_policy}"

python3 scripts/experiments/ecg/final_paper_run.py \
  --profile "$profile" \
  --run-dir "$run_dir" \
  --only "$stage" \
  --graph "$graph" \
  --benchmark "$benchmark" \
  --policy "$policy" \
  --no-build
