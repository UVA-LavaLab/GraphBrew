	keywords = {BFS, Clustering algorithms, Data structures, GPU system, Runtime, Social network services, Sockets, Switches, Tuning, bottom-up algorithm, breadth-first search, graph edges, graph theory, graph-processing applications, graphics processing units, hybrid approach, low-diameter scale-free input graphs, multicore system, multisocket server, network theory (graphs), search problems, shared memory implementations, shared memory systems, social networks, standard synthetic graphs, top-down algorithm},
	pages = {1--10},
}

