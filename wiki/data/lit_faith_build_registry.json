  "cxxflags": {
    "cache_sim": {
      "live_flags": "-std=c++17 -O3 -Wall -fopenmp -g -DNDEBUG",
      "opt_level": "-O3",
      "required_tokens": [
        "-std=c++17",
        "-Wall",
        "-fopenmp",
        "-DNDEBUG"
      ],
      "var_name": "CXXFLAGS_GAP"
    },
    "gem5": {
      "live_flags": "-std=c++17 -O1 -Wall -g -DNDEBUG -DNO_M5OPS -fopenmp",
      "opt_level": "-O1",
      "required_tokens": [
        "-std=c++17",
        "-Wall",
        "-fopenmp",
        "-DNDEBUG",
        "-DNO_M5OPS"
      ],
      "var_name": "CXXFLAGS_GEM5"
    },
    "native": {
      "live_flags": "-std=c++17 -O3 -Wall -fopenmp -g -DNDEBUG",
      "opt_level": "-O3",
      "required_tokens": [
        "-std=c++17",
        "-Wall",
        "-fopenmp",
        "-DNDEBUG"
      ],
      "var_name": "CXXFLAGS_GAP"
    },
    "sniper": {
      "live_flags": "-std=c++17 -O2 -Wall -g -DNDEBUG -fopenmp -I$(INC_DIR) -I$(SNIPER_INCLUDE)",
      "opt_level": "-O2",
      "required_tokens": [
        "-std=c++17",
        "-Wall",
        "-fopenmp",
        "-DNDEBUG",
        "-I$(SNIPER_INCLUDE)"
      ],
      "var_name": "CXXFLAGS_SNIPER"
    }
