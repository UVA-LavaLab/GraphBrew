+bool
+graphbrewStreamBypass(const BaseCache &cache, const PacketPtr pkt)
+{
+    if (cache.name().find("l3cache") == std::string::npos)
+        return false;
+    const Addr stream_addr = pkt->req->hasVaddr()
+        ? pkt->req->getVaddr() : pkt->getAddr();
+    const bool bypass =
+        replacement_policy::graph::isEcgStreamBypassAddress(stream_addr);
+    if (bypass) {
+        static uint64_t traced = 0;
+        static const uint64_t limit = []() {
+            const char *value = std::getenv("ECG_STREAM_BYPASS_TRACE");
+            return value ? std::strtoull(value, nullptr, 10) : 0;
+        }();
+        if (traced++ < limit) {
+            std::fprintf(stderr,
+                "[ECG-STREAM-BYPASS sim=gem5 cache=%s addr=%#llx "
+                "vaddr=%#llx allocate=0]\n",
+                cache.name().c_str(),
+                static_cast<unsigned long long>(pkt->getAddr()),
+                static_cast<unsigned long long>(stream_addr));
+        }
+    }
+    return bypass;
+}
