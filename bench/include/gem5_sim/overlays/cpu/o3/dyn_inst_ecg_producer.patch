+    uint32_t _ecgDest = 0;
+    uint16_t _ecgEpoch = 0;
+    bool _ecgValid = false;
+
+  public:
+    void setEcgLoadHint(uint32_t dest, uint16_t epoch) override
+    { _ecgDest = dest; _ecgEpoch = epoch; _ecgValid = true; }
+    bool ecgLoadHint(uint32_t &dest, uint16_t &epoch) const
+    { dest = _ecgDest; epoch = _ecgEpoch; return _ecgValid; }
+
