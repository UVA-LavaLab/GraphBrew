  "performance_contract": {
    "bfs": {
      "edge_work": "direction_optimized_O(V+E)",
      "edge_balance": "thread_local_unique_frontier_push_and_dynamic_destination_pull",
      "ownership": "CAS_push_destination_owned_pull"
    },
    "bc": {
      "edge_work": "sampled_brandes_O(k*(V+E))",
      "edge_balance": "frontier_push_and_depth_owned_backward_gather",
      "ownership": "atomic_path_counts_vertex_owned_dependencies"
    },
    "cc": {
      "edge_work": "afforest_sample_then_near_linear_union",
      "edge_balance": "dynamic_source_rows_with_frequent_component_skip",
      "ownership": "atomic_union_find",
      "gas_work": "active_weak_neighbor_edges"
    },
    "cc_sv": {
      "edge_work": "iterative_hook_and_shortcut",
      "edge_balance": "direct_source_rows_with_oriented_filter",
      "ownership": "CAS_root_hook_vertex_shortcut"
    },
    "pr": {
      "edge_work": "O(iterations*(V+E))",
      "edge_balance": "edge_balanced_destination_segments",
      "ownership": "destination_owned_atomic_contribution_reads",
      "gas_work": "dense_gather_apply_scatter"
    },
    "pr_spmv": {
      "edge_work": "O(iterations*(V+E))",
      "edge_balance": "edge_balanced_destination_segments",
      "ownership": "destination_owned_jacobi_gather"
    },
    "sssp": {
