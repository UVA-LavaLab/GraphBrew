      "edge_balance": "dynamic_active_frontier_with_thread_local_bins",
      "ownership": "atomic_min_distance",
      "gas_work": "active_bellman_ford_edges"
    },
    "tc": {
      "edge_work": "sum_oriented_sorted_prefix_intersections",
      "edge_balance": "dynamic_source_rows_with_oriented_edges",
      "ownership": "thread_local_count_reduction"
    }
  },
